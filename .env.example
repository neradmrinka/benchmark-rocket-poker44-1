# Copy to `.env` (gitignored) and fill in. model/ecosystem.config.js reads it and
# passes it to pm2; model_identity.py also reads it directly so a bare
# `python3 model/poker44_miner.py` behaves the same. Nothing here is ever committed.

# --- wallet / axon ----------------------------------------------------------
POKER44_WALLET_NAME=your_coldkey_wallet_name
POKER44_WALLET_HOTKEY=your_hotkey_name
POKER44_NETUID=126
POKER44_AXON_PORT=8091

# --- published identity -----------------------------------------------------
# These three end up in the model manifest. A validator that cannot verify them
# marks the miner `opaque` and applies a transparency penalty, so they are not
# optional decoration.

# The PUBLIC repo this miner's source is published at. Must not be the reference
# subnet repo (poker44/utils/model_manifest.py rejects that as a policy violation).
POKER44_MODEL_REPO_URL=https://github.com/<you>/<your-miner-repo>

# Shown as manifest.model_name. Keep it distinct per miner.
POKER44_MODEL_NAME=rocket-r1

# pm2 process name. autopilot.py restarts THIS process after a promotion, so it
# must match the name pm2 actually registered.
POKER44_PM2_NAME=poker44_miner_r1

# Optional: pin the published commit. Leave EMPTY to publish the checkout's git HEAD
# (recommended — it cannot go stale). If you set it, it must be a real 7-40 char hex
# sha that is pushed to POKER44_MODEL_REPO_URL, or the manifest fails verification.
POKER44_MODEL_REPO_COMMIT=

# --- optional tuning --------------------------------------------------------
# POKER44_PYTHON=/path/to/miner_env/bin/python   # default: <repo>/miner_env/bin/python
# POKER44_TRAIN_JOBS=4        # cores per component during training
# POKER44_WF_POINTS=4         # walk-forward dates used to fit blend weights
# POKER44_MAX_POS_FRAC=0.15   # cap on the positive rate per batch (ranking untouched)
# POKER44_PROBE_RATE=20       # sample 1 in N live batches for the drift probe
